{
  "version": "1.0.0",
  "pipeline": "forge",
  "trigger": "/forge",
  "fix_trigger": "/fix",
  "storage_dir": ".jwforge",
  "phases": [
    {
      "phase": 1,
      "name": "Discover",
      "description": "Interview + requirements analysis",
      "required_artifacts": [],
      "user_wait_steps": ["1-3"],
      "steps": [
        {"id": "1-1", "name": "interview", "description": "Structured user interview (opus)"},
        {"id": "1-2", "name": "analyze", "description": "Requirements analysis → task-spec.md (opus)"},
        {"id": "1-3", "name": "review", "description": "Spec validation gate (opus) — user gate after"}
      ]
    },
    {
      "phase": 2,
      "name": "Design",
      "description": "Codebase analysis + architecture design",
      "required_artifacts": ["task-spec.md"],
      "user_wait_steps": ["2-3"],
      "steps": [
        {"id": "2-1", "name": "research", "description": "Parallel codebase analysis (sonnet × N)"},
        {"id": "2-2", "name": "design", "description": "Architecture design → architecture.md (opus)"},
        {"id": "2-3", "name": "review", "description": "Design validation gate (opus) — user gate after"}
      ]
    },
    {
      "phase": 3,
      "name": "Build",
      "description": "TDD unit-by-unit implementation",
      "required_artifacts": ["task-spec.md", "architecture.md"],
      "user_wait_steps": [],
      "steps": [
        {"id": "3-N", "name": "unit-cycle", "description": "Per unit: test-writer → executor → code-reviewer → commit"}
      ]
    },
    {
      "phase": 4,
      "name": "Validate",
      "description": "Cross-unit verification + fix loop + integration",
      "required_artifacts": ["task-spec.md", "architecture.md"],
      "user_wait_steps": [],
      "steps": [
        {"id": "4-1", "name": "verify", "description": "Cross-unit integration check (opus)"},
        {"id": "4-2", "name": "fix", "description": "Issue resolution (sonnet→opus)"},
        {"id": "4-3", "name": "test", "description": "Integration test runner (sonnet)"},
        {"id": "4-4", "name": "final-review", "description": "Final validation gate (opus)"}
      ]
    }
  ],
  "valid_steps": [
    "1-1", "1-2", "1-3",
    "2-1", "2-2", "2-3",
    "3-N",
    "4-1", "4-2", "4-3", "4-4"
  ],
  "fix_mode": {
    "description": "Standalone error-fixing mode triggered by /fix. Phase 4 only.",
    "entry_phase": 4,
    "entry_step": "4-1",
    "steps": ["4-1", "4-2", "4-3", "4-4"]
  },
  "complexity_shortcuts": {
    "S": {
      "description": "Simple tasks skip Phase 2 (Design), go from Phase 1 to Phase 3",
      "skip_phases": [2]
    }
  },
  "models": {
    "interviewer": "opus",
    "analyst": "opus",
    "researcher": "sonnet",
    "designer": "opus",
    "reviewer": "opus",
    "test_writer": "sonnet",
    "executor": "sonnet",
    "code_reviewer": "sonnet",
    "verifier": "opus",
    "fixer_initial": "sonnet",
    "fixer_upgrade": "opus",
    "state_recorder": "haiku",
    "haiku_collector": "haiku"
  },
  "limits": {
    "max_executor_retries": 3,
    "max_fix_iterations": 5,
    "max_analysis_agents": 4
  },
  "tdd": {
    "enforce": true,
    "guard_mode": "block"
  },
  "git": {
    "commit_prefix": "[forge]"
  },
  "cost_warning": {
    "enabled": true,
    "show_agent_estimate": true,
    "confirm_on_xl": true
  },
  "state_schema": {
    "description": "Authoritative shape of .jwforge/current/state.json",
    "fields": {
      "pipeline": "string — always 'forge'",
      "task": "string — user task description",
      "started_at": "ISO8601 timestamp",
      "phase": "number — 1|2|3|4",
      "step": "string — step ID",
      "complexity": "string — S|M|L|XL",
      "type": "string — feature|refactor|bugfix|docs",
      "status": "string — in_progress|done|stopped",
      "team_name": "string|null",
      "team_mode": "string — teams|subagent_only",
      "waiting_for_user": "boolean",
      "empty_project": "boolean",
      "phase1": {
        "status": "pending|in_progress|done",
        "interview_round": "number",
        "researcher_validated": "boolean",
        "reviewer_passed": "boolean"
      },
      "phase2": {
        "status": "pending|in_progress|done",
        "analysis_complete": "boolean",
        "designer_complete": "boolean",
        "reviewer_passed": "boolean"
      },
      "phase3": {
        "status": "pending|in_progress|done",
        "current_unit": "number",
        "total_units": "number",
        "completed_units": "number[]",
        "current_unit_test_written": "boolean",
        "retries": "object"
      },
      "phase4": {
        "status": "pending|in_progress|done",
        "verify_complete": "boolean",
        "fix_loop_count": "number",
        "integration_test_complete": "boolean",
        "reviewer_passed": "boolean"
      },
      "stopped_at": "ISO8601|null",
      "stop_reason": "string|null"
    },
    "legal_transitions": {
      "status": {
        "in_progress": ["done", "stopped"],
        "stopped": ["in_progress"],
        "done": []
      },
      "phase": {
        "description": "Phase advances by 1 only. Never regress. S complexity: 1→3.",
        "max_advance": 1,
        "s_complexity_skip": "1→3"
      },
      "phaseN_status": {
        "description": "Each phase sub-status: pending→in_progress→done",
        "transitions": {
          "pending": ["in_progress"],
          "in_progress": ["done"],
          "done": []
        }
      }
    }
  }
}
