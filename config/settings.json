{
  "name": "jwforge",
  "version": "0.2.0",
  "description": "Team-based multi-agent orchestration pipeline for Claude Code",
  "triggers": ["/deep", "/surface", "/resume", "/selfdeep"],
  "skill_path": "skills/jwforge.md",
  "agents_dir": "agents/",
  "templates_dir": "templates/",
  "storage_dir": ".jwforge/",
  "defaults": {
    "architect_model": "opus",
    "designer_model": "opus",
    "reviewer_model": "opus",
    "min_executor_model": "sonnet",
    "analyzer_model": "sonnet",
    "tester_model": "sonnet",
    "fixer_model_initial": "sonnet",
    "fixer_model_upgrade": "opus",
    "haiku_collector_model": "haiku",
    "max_parallel_analyzers": 10,
    "max_retry_count": 3,
    "max_architect_redesign_retry": 2
  },
  "team": {
    "members": ["conductor", "architect", "reviewer"],
    "subagents": ["executor", "analyzer", "tester", "fixer"]
  },
  "git": {
    "commit_prefix": "[jwforge]",
    "impl_done_tag": "jwforge/impl-done"
  },
  "surface": {
    "executor_model": "sonnet",
    "haiku_model": "haiku",
    "max_executor_count": 2,
    "max_retry_count": 1,
    "commit_prefix": "[jwforge-surface]"
  },
  "selfdeep": {
    "sandbox_path": "~/.claude/jwforge-sandbox/",
    "analyzer_model": "sonnet",
    "researcher_model": "sonnet",
    "improver_model": "opus",
    "verifier_model": "sonnet",
    "reporter_model": "sonnet",
    "conversation_log_path": "~/.claude/projects/",
    "archive_path": ".jwforge/archive/",
    "notion_fallback": "terminal",
    "auto_fix_on_verify_fail": true,
    "max_improvements_per_run": 10
  },
  "cost_warning": {
    "enabled": true,
    "show_agent_estimate": true,
    "confirm_on_xl": true
  },
  "notifications": {
    "enabled": true,
    "triggers": ["phase_transition", "user_input_wait", "pipeline_complete", "pipeline_failure"]
  }
}
