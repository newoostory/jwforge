{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/trigger.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/phase-guard.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/state-validator.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/commit-guard.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/lifecycle.mjs compact",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/lifecycle.mjs stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
