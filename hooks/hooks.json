{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/trigger.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/tdd-guard.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/tdd-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/state-validator.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/artifact-validator.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/commit-guard.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/agent-bg-guard.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/subagent-tracker.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/notify.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/notify.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/pre-compact.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/persistent-mode.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/on-stop.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"{{INSTALL_DIR}}\"/hooks/notify.mjs",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
